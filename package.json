{
    "name": "clockmind-fun-time-learning",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "lint:fix": "eslint . --ext .ts,.tsx --fix",
        "preview": "vite preview",
        "format": "prettier --write ./src/**/*.{tsx,ts,json}",
        "format:check": "prettier --check ./src/**/*.{tsx,ts,json}",
        "tsc:check": "tsc --noEmit",
        "storybook": "storybook dev -p 6006",
        "storybook:test": "yarn vitest --project=storybook",
        "build-storybook": "storybook build",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:coverage:all": "node scripts/merge-coverage.cjs",
        "prepare": "husky install",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed"
    },
    "dependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.2.0",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "clsx": "^2.1.1",
        "dependency-cruiser": "^17.3.8",
        "i18next": "^25.8.13",
        "lucide-react": "^0.575.0",
        "motion": "^12.34.3",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-i18next": "^16.5.4",
        "react-router": "^7.13.1",
        "tailwindcss": "^4.2.0"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@chromatic-com/storybook": "^5.0.1",
        "@eslint/js": "^9.39.1",
        "@storybook/addon-a11y": "^10.2.13",
        "@storybook/addon-docs": "^10.2.13",
        "@storybook/addon-mcp": "^0.3.3",
        "@storybook/addon-onboarding": "^10.2.13",
        "@storybook/addon-vitest": "^10.2.13",
        "@storybook/react-vite": "^10.2.13",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.2.2",
        "@vitest/browser-playwright": "^4.0.18",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^9.39.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "eslint-plugin-sort-keys-fix": "^1.1.2",
        "eslint-plugin-storybook": "^10.2.13",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "nyc": "^18.0.0",
        "playwright": "^1.58.2",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "storybook": "^10.2.13",
        "storybook-addon-remix-react-router": "6",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.0.18",
        "workbox-window": "^7.4.0"
    }
}
